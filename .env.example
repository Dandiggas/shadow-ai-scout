# Required for live agentic scan
TAVILY_API_KEY=

# LLM provider for evidence extraction: anthropic (default) or gemini.
# If unset, Anthropic is used when ANTHROPIC_API_KEY is present, else Gemini.
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional model + token overrides
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=2048

# Gemini — used when LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Alternative to GEMINI_API_KEY:
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Optional ClickHouse target if you apply generated SQL directly
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=shadow_ai_scout

# Optional alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
